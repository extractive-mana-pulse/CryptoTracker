<?xml version="1.0" encoding="utf-8"?>
<!--
    4dp filled circle used as data-point dots on the chart preview line.
    Color matches the chart line color token for light theme;
    in dark theme the widget_background switches automatically but this dot
    is baked into the preview only — real chart is drawn by GlanceLineChart.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#FF2563EB" />
</shape>